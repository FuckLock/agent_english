{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/detect-feedback-signal.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/check-evolution.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/pre-commit-check.sh",
            "timeout": 30
          }
        ],
        "matcher": "^git commit(\\s|$)"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/kill-dev-ports.sh",
            "timeout": 10
          }
        ],
        "matcher": "^(pnpm|npm|yarn)\\s+(run\\s+)?dev(\\s|$)"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/auto-push.sh",
            "timeout": 15
          }
        ],
        "matcher": "^git commit(\\s|$)"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/mark-review-needed.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "./.codex/hooks/stop-gate.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
